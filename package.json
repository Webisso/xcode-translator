{
  "name": "xcode-translator",
  "version": "1.0.0",
  "description": "CLI tool to translate Xcode Localizable.strings using Gemini AI",
  "type": "module",
  "bin": {
    "xcode-translator": "./dist/cli.js"
  },
  "files": [
    "dist",
    "prompts"
  ],
  "scripts": {
    "build": "tsc && cp -r prompts dist/prompts",
    "prepare": "npm run build",
    "start": "node dist/cli.js",
    "dev": "npm run build && node dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "xcode",
    "localization",
    "gemini",
    "cli",
    "i18n"
  ],
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "@inquirer/prompts": "^7.5.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}
